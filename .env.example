# --- General ---
ENVIRONMENT=test                        # test (no tweets sent) or prod
INTERVAL_MINUTES=2                      # how often the bot polls the API
GITHUB_TOKEN=                           # for installing arodsgntfy at build time

# --- API service ---
NOHITTERTRACKER_SCHEDULE_CACHE_TTL_SECONDS=60
NOHITTERTRACKER_GAME_FEED_FINAL_CACHE_TTL_SECONDS=21600
NOHITTERTRACKER_GAME_FEED_SCHEDULED_CACHE_TTL_SECONDS=3600
NOHITTERTRACKER_GAME_FEED_NEAR_START_CACHE_TTL_SECONDS=60
NOHITTERTRACKER_GAME_FEED_NEAR_START_WINDOW_SECONDS=1800

# --- Bot service ---
API_BASE_URL=                           # internal Railway URL of the API service
TWITTER_CONSUMER_KEY=
TWITTER_CONSUMER_SECRET=
TWITTER_ACCESS_TOKEN=
TWITTER_ACCESS_TOKEN_SECRET=